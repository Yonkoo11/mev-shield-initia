# MEV Shield Initia - Environment Variables
# Copy to .env.local and fill in values

# RPC endpoint for the Minitia rollup
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Chain ID (default: Minitia local)
NEXT_PUBLIC_CHAIN_ID=1411570067076288

# Deployed contract addresses
NEXT_PUBLIC_AUCTION_ADDRESS=0x5dDAee13AAdFa374DBd62811412C280d78e1f9BB
NEXT_PUBLIC_TOKEN_A_ADDRESS=0x3cBb5A79CB5702b9AEc850D0C6c6F47F79200057
NEXT_PUBLIC_TOKEN_B_ADDRESS=0x4A46e1e80e5e5718e9B2294d312AAc0fE4Bd2668

# Site URL for OG images
NEXT_PUBLIC_SITE_URL=https://mev-shield-initia.netlify.app
